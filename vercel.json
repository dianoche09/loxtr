{
    "version": 2,
    "crons": [
        {
            "path": "/api/public?keepalive=true",
            "schedule": "0 6 */3 * *"
        }
    ],
    "buildCommand": "npm run build --prefix frontend",
    "outputDirectory": "frontend/dist",
    "installCommand": "npm install && npm install --prefix frontend --legacy-peer-deps",
    "framework": "vite",
    "devCommand": "npm run dev --prefix frontend",
    "rewrites": [
        {
            "source": "/api/ai/discover-suggestions",
            "destination": "/api/ai?action=discover-suggestions"
        },
        {
            "source": "/api/ai/suggest",
            "destination": "/api/ai?action=suggest"
        },
        {
            "source": "/api/ai/generate-email",
            "destination": "/api/ai?action=generate-email"
        },
        {
            "source": "/api/leads/discover-batch",
            "destination": "/api/discovery/run"
        },
        {
            "source": "/api/leads/batch",
            "destination": "/api/leads?action=batch"
        },
        {
            "source": "/api/leads/stats",
            "destination": "/api/leads?action=stats"
        },
        {
            "source": "/api/leads/:id",
            "destination": "/api/leads?id=:id"
        },
        {
            "source": "/api/contact",
            "destination": "/api/public?action=contact"
        },
        {
            "source": "/api/newsletter",
            "destination": "/api/public?action=newsletter"
        },
        {
            "source": "/api/application",
            "destination": "/api/public?action=application"
        },
        {
            "source": "/api/dashboard/summary",
            "destination": "/api/auth/me?action=dashboard-summary"
        },
        {
            "source": "/api/dashboard/briefing",
            "destination": "/api/auth/me?action=dashboard-summary"
        },
        {
            "source": "/api/loxconvert/generate-comment",
            "destination": "/api/loxconvert/extra?action=generate-comment"
        },
        {
            "source": "/api/loxconvert/generate-invoice",
            "destination": "/api/loxconvert/extra?action=generate-invoice"
        },
        {
            "source": "/api/loxconvert/insights",
            "destination": "/api/loxconvert/extra?action=insights"
        },
        {
            "source": "/api/:path*",
            "destination": "/api/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}